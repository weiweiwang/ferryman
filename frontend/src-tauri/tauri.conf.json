{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferryman",
  "version": "0.3.0",
  "identifier": "app.ferryman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run stage-backend && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ferryman",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "resources": [
      "gen/backend-sidecar",
      "gen/skills"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
