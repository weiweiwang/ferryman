# Copy this file to .env.release.local for local release builds.
# Never commit .env.release.local or Apple private key files.

# Developer ID signing identity, for example:
# APPLE_SIGNING_IDENTITY='Developer ID Application: Example Company (TEAMID1234)'
APPLE_SIGNING_IDENTITY=''

# Apple notarization API credentials.
# Keep the .p8 file outside the repository, for example under ~/.private_keys/.
APPLE_NOTARY_ISSUER_ID=''
APPLE_NOTARY_KEY_ID=''
APPLE_NOTARY_KEY_PATH=''
